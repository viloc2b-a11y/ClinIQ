# -----------------------------------------------------------------------------
# ClinIQ — Supabase self-hosted (VPS)
# -----------------------------------------------------------------------------
# Copy to `.env.local` and fill in values from your instance.
# Do not commit `.env.local`. Schema changes: use your Supabase Studio UI, not
# supabase.com cloud link/login (self-hosted workflow).
# -----------------------------------------------------------------------------

# API URL of your self-hosted stack (Kong / API gateway)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-host.example.com

# Anon key (browser + RLS-protected reads; safe to expose with strict RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt

# Service role — server-only (Route Handlers, server scripts). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# -----------------------------------------------------------------------------
# Admin (/admin) — allowlist + invite emails
# -----------------------------------------------------------------------------
# Comma-separated emails allowed to access /admin and call POST /api/admin/invite.
# In production, if empty, nobody is admin. In development, empty list allows any signed-in user.
# CLINIQ_ADMIN_EMAILS=you@example.com,ops@example.com

# Public URL of this Next app (no trailing slash). Used in Supabase invite redirect links.
# CLINIQ_PUBLIC_APP_URL=https://app.cliniqcloud.com

# If set, POST /api/ingest-event requires header: Authorization: Bearer <same value>
# CLINIQ_API_SECRET=

# Production ingest: expected billables load from DB (published baseline). Set to 1 only for tests/tools
# to send expectedBillables in the JSON body.
# CLINIQ_INGEST_ALLOW_BODY_EXPECTED_BILLABLES=1

# MVP dashboard/counteroffer: when 1, do not fall back to mock data on API failure (show explicit error).
# NEXT_PUBLIC_CLINIQ_MVP_STRICT=1

# Optional: direct Postgres for local tools (psql, GUI). Never use in client code.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_VPS_IP:5432/postgres

# -----------------------------------------------------------------------------
# Action Center — persistence (STEP 6 cutover)
# -----------------------------------------------------------------------------
# Document Engine boundary writes: opt-in for real persistence (default off).
# When true, also set CLINIQ_ACTION_CENTER_PERSISTENCE_MODE=supabase and server Supabase vars.
# ENABLE_ACTION_CENTER_PERSISTENCE=false
# Default: in-memory shared store (no DB). Safe for local dev and demos.
CLINIQ_ACTION_CENTER_PERSISTENCE_MODE=memory
#
# Opt-in: persist Action Center items in Postgres via Supabase (service role).
# Uncomment and set mode + the same server vars as above (placeholders only here).
# CLINIQ_ACTION_CENTER_PERSISTENCE_MODE=supabase
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Additive Action Center record store (lib/action-center/persistence) — Step 54/55
# -----------------------------------------------------------------------------
# Default off: in-memory adapter. When true, uses SupabasePersistenceAdapter + table action_center_records.
# CLINIQ_ENABLE_REAL_PERSISTENCE=false
# Server-only URL for lib/integrations/supabase/client.ts (falls back safely if unset).
# SUPABASE_URL=
# Reuse SUPABASE_SERVICE_ROLE_KEY from above when enabling real persistence for this layer.
